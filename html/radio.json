{
  "environment": {
    "base_dir": "/config/www/",
    "asset_dir": "/config/www/local/",
    "web_path": "/local/radio.html"
  },
  "token_configuration": {
    "filename": "token.txt",
    "target_path": "/config/www/token.txt"
  },
  "ui_configuration": {
    "panel_title": "📻 Radio Controller",
    "stations": [
      {
        "entity_id": "switch.radio1",
        "display_name": "BBC Radio 1",
        "logo_path": "/local/bbc_radio_1.svg"
      },
      {
        "entity_id": "switch.radio2",
        "display_name": "BBC Radio 2",
        "logo_path": "/local/bbc_radio_2.svg"
      },
      {
        "entity_id": "switch.radio3",
        "display_name": "BBC Radio 3",
        "logo_path": "/local/bbc_radio_3.svg"
      },
      {
        "entity_id": "switch.radio4",
        "display_name": "BBC Radio 4",
        "logo_path": "/local/bbc_radio_4.svg"
      },
      {
        "entity_id": "switch.radio5",
        "display_name": "BBC Radio 5 Live",
        "logo_path": "/local/bbc_radio_5.svg"
      },
      {
        "entity_id": "switch.radio6",
        "display_name": "BBC Radio 6 Music",
        "logo_path": "/local/bbc_radio_6.svg"
      }
    ]
  },
  "source_code": {
    "filename": "radio.html",
    "target_path": "/config/www/radio.html",
    "html_content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\">\n    <title>Radio Controller</title>\n    <style>\n        :root {\n            --bg-color: #0f0f11;\n            --card-color: #16161a;\n            --text-color: #f1f5f9;\n            --accent-color: #38bdf8;\n            --border-color: #27272a;\n            --sub-text: #a1a1aa;\n        }\n\n        * {\n            box-sizing: border-box;\n            margin: 0;\n            padding: 0;\n            user-select: none;\n            -webkit-user-select: none;\n        }\n\n        body {\n            font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif;\n            background-color: var(--bg-color);\n            color: var(--text-color);\n            padding: 20px;\n            overflow-y: auto;\n            height: 100vh;\n        }\n\n        .container {\n            max-width: 800px;\n            margin: 0 auto;\n            display: flex;\n            flex-direction: column;\n            height: 100%;\n        }\n\n        header {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            margin-bottom: 20px;\n            padding-bottom: 12px;\n            border-bottom: 2px solid var(--border-color);\n        }\n\n        h1 { font-size: 2.3rem; font-weight: 800; }\n\n        .radio-grid {\n            display: grid;\n            grid-template-columns: repeat(2, 1fr);\n            gap: 16px;\n            flex-grow: 1;\n            padding-bottom: 20px;\n        }\n\n        .radio-btn {\n            background-color: var(--card-color);\n            border: 2px solid var(--border-color);\n            border-radius: 14px;\n            padding: 20px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            cursor: pointer;\n            position: relative;\n            overflow: hidden;\n            touch-action: manipulation;\n            transition: border-color 0.15s ease, background 0.15s ease, box-shadow 0.15s ease;\n        }\n\n        .station-logo {\n            max-width: 80%;\n            max-height: 55px;\n            object-fit: contain;\n            filter: invert(1) brightness(0.9);\n            transition: filter 0.15s ease, transform 0.15s ease;\n        }\n\n        .radio-btn.active {\n            border-color: var(--accent-color);\n            background: linear-gradient(145deg, #1e293b, #16161a);\n            box-shadow: 0 0 15px rgba(56, 189, 248, 0.15);\n        }\n\n        .radio-btn.active .station-logo {\n            filter: none;\n            transform: scale(1.05);\n        }\n\n        .indicator {\n            position: absolute;\n            top: 14px;\n            right: 16px;\n            width: 8px;\n            height: 8px;\n            border-radius: 50%;\n            background-color: #27272a;\n            border: 1px solid #3f3f46;\n        } \n\n        .radio-btn.active .indicator {\n            background-color: var(--accent-color);\n            box-shadow: 0 0 8px var(--accent-color);\n            border-color: transparent;\n        }\n\n        .token-gate {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100vw;\n            height: 100vh;\n            background: rgba(15, 15, 17, 0.98);\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            padding: 24px;\n            z-index: 9999;\n        }\n\n        .gate-box {\n            background: var(--card-color);\n            border: 1px solid var(--border-color);\n            padding: 30px;\n            border-radius: 12px;\n            max-width: 500px;\n            width: 100%;\n            text-align: center;\n        }\n        .gate-box h2 { font-size: 1.8rem; margin-bottom: 12px; }\n        .gate-box p { color: var(--sub-text); margin-bottom: 20px; }\n    </style>\n</head>\n<body>\n    <div id=\"setup-gate\" class=\"token-gate\">\n        <div class=\"gate-box\">\n            <h2>🔒 Initializing Radio Controller</h2>\n            <p id=\"gate-msg\">Reading local configurations...</p>\n        </div>\n    </div>\n    <div class=\"container\">\n        <header>\n            <h1 id=\"main-title\"></h1>\n        </header>\n        <div class=\"radio-grid\" id=\"grid-container\"></div>\n    </div>\n    <script>\n        const HA_URL = window.location.origin;\n        let CONFIG = null;\n        let SWITCHES = [];\n        let ACCESS_TOKEN = localStorage.getItem('ha_secure_token');\n        let messageId = 10;\n        const setupGate = document.getElementById('setup-gate');\n        const gateMsg = document.getElementById('gate-msg');\n        async function loadConfigAndVerifyToken() {\n            try {\n                const response = await fetch('radio_config.json');\n                if (!response.ok) throw new Error(\"Config JSON not found\");\n                const data = await response.json();\n                CONFIG = data.ui_configuration;\n                SWITCHES = CONFIG.stations.map(s => s.entity_id);\n                document.getElementById('main-title').innerText = CONFIG.panel_title;\n                const container = document.getElementById('grid-container');\n                CONFIG.stations.forEach(station => {\n                    const btn = document.createElement('div');\n                    btn.className = 'radio-btn';\n                    btn.setAttribute('data-id', station.entity_id);\n                    btn.innerHTML = `<div class=\"indicator\"></div><img class=\"station-logo\" src=\"${station.logo_path}\" alt=\"${station.display_name}\">`;\n                    container.appendChild(btn);\n                });\n                if (ACCESS_TOKEN) {\n                    setupGate.style.display = 'none';\n                    initRadioController();\n                } else {\n                    readTokenFile();\n                }\n            } catch (err) {\n                gateMsg.innerHTML = `<span style=\"color:#ef4444\">Error parsing UI configuration map!</span>`;\n            }\n        }\n        async function readTokenFile() {\n            gateMsg.innerText = \"Checking file system for token.txt entry...\";\n            try {\n                const response = await fetch('token.txt');\n                if (!response.ok) throw new Error(\"File not found\");\n                const fileText = await response.text();\n                const cleanToken = fileText.trim();\n                if (cleanToken.length > 10) {\n                    localStorage.setItem('ha_secure_token', cleanToken);\n                    ACCESS_TOKEN = cleanToken;\n                    gateMsg.innerText = \"Token verified! Loading interface...\";\n                    setTimeout(() => {\n                        setupGate.style.display = 'none';\n                        initRadioController();\n                    }, 800);\n                } else {\n                    gateMsg.innerHTML = `<span style=\"color:#ef4444\">Error: token.txt is empty!</span>`;\n                }\n            } catch (err) {\n                gateMsg.innerHTML = `<span style=\"color:#ef4444\">Config Missing!<br>Please drop your token string inside /www/token.txt</span>`;\n            }\n        }\n        function initRadioController() {\n            const wsUrl = HA_URL.replace(/^http/, 'ws') + '/api/websocket';\n            const socket = new WebSocket(wsUrl);\n            socket.onopen = () => { socket.send(JSON.stringify({ type: \"auth\", access_token: ACCESS_TOKEN })); };\n            socket.onmessage = (event) => {\n                const response = JSON.parse(event.data);\n                if (response.type === \"auth_invalid\") { localStorage.removeItem('ha_secure_token'); window.location.reload(); }\n                if (response.type === \"auth_ok\") {\n                    socket.send(JSON.stringify({ id: 1, type: \"subscribe_events\", event_type: \"state_changed\" }));\n                    socket.send(JSON.stringify({ id: 2, type: \"get_states\" }));\n                }\n                if (response.id === 2 && response.type === \"result\") {\n                    response.result.forEach(state => { if (SWITCHES.includes(state.entity_id)) { updateButtonUI(state.entity_id, state.state); } });\n                }\n                if (response.type === \"event\" && response.id === 1) {\n                    const eventData = response.event.data;\n                    if (SWITCHES.includes(eventData.entity_id)) { const targetState = eventData.new_state ? eventData.new_state.state : \"off\"; updateButtonUI(eventData.entity_id, targetState); }\n                }\n            };\n            const radioButtons = document.querySelectorAll('.radio-btn');\n            function handleStationPress(btn) {\n                const entityId = btn.getAttribute('data-id');\n                const isCurrentlyActive = btn.classList.contains('active');\n                socket.send(JSON.stringify({ id: messageId++, type: \"call_service\", domain: \"switch\", service: isCurrentlyActive ? \"turn_off\" : \"turn_on\", service_data: { entity_id: entityId } }));\n            }\n            radioButtons.forEach(btn => { btn.addEventListener('click', (e) => { if (e.button === 0 || e.button === undefined) { handleStationPress(btn); } }); });\n        }\n        function updateButtonUI(entityId, state) {\n            const btn = document.querySelector(`.radio-btn[data-id=\"${entityId}\"]`);\n            if (!btn) return;\n            if (state === \"on\") { btn.classList.add('active'); } else { btn.classList.remove('active'); }\n        }\n        loadConfigAndVerifyToken();\n    </script>\n</body>\n</html>"
  }
}